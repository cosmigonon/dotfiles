" cosmigonon's vimrc config 

"""" Basic behavior

set history=1000
set encoding=utf-8
set number relativenumber
set mouse=a
set wrap
set wildmenu
set showmatch
set laststatus=2
set ruler
syntax on
set nobackup
set nowritebackup
set noswapfile
set clipboard^=unnamed,unnamedplus

"""" Tab setttings

set expandtab
set shiftwidth=4
set softtabstop=4
set ignorecase

set autoindent
set smartindent

"""" Search settings

set hlsearch


